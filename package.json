{
  "name": "cptracker-extension",
  "displayName": "CPTracker - Track your progress",
  "version": "0.0.1",
  "description": "Extension support for www.cptracker.org. Direct note taking & time tracking on leetcode problems.",
  "author": "<belgutei0323@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "better-auth": "^1.5.1",
    "plasmo": "0.90.5",
    "re-resizable": "^6.11.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "storage"
    ],
    "host_permissions": [
      "https://www.cptracker.org/*",
      "http://localhost:3000/*"
    ]
  }
}
